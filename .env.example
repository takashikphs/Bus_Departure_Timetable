# Port the app listens on (default: 8888)
PORT=8888

# How often (seconds) to re-poll OVapi in the background (default: 30)
REFRESH_INTERVAL=30

# ── Stop configuration ──────────────────────────────────────────────────────
# Display names for your stops (shown in the UI)
HOME_STOP_NAME=My Stop
CITY_STOP_NAME=City Terminal

# OVAPI timing-point codes (TPC) — find yours at https://ovzoeker.nl
# TPC_HOME_OUTBOUND: nearest timing point on the outbound route from your home stop
# TPC_CITY_INBOUND:  city terminal timing point for buses heading toward your home
TPC_HOME_OUTBOUND=YOUR_OUTBOUND_TPC_CODE
TPC_CITY_INBOUND=YOUR_INBOUND_TPC_CODE

# Comma-separated line numbers to track (e.g. 4,54)
ROUTES=4,54

# ── Travel time offsets ──────────────────────────────────────────────────────
# Minutes from the city terminal timing point to your home stop
CITY_TO_HOME_MIN=7
# Minutes from your home stop to the outbound proxy timing point
PROXY_OFFSET_MIN=6

# ── Map & weather ────────────────────────────────────────────────────────────
# Coordinates for the map centre and weather fetch (your general area)
MAP_LAT=52.0
MAP_LON=4.5

# ── Push notifications (ntfy.sh) ─────────────────────────────────────────────
# Subscribe to this topic in the ntfy app to receive bus alerts
NTFY_TOPIC=your-ntfy-topic-here
NOTIFY_AT_MIN=5
NOTIFY_COOLDOWN_MIN=20

# ── Commute ETA ──────────────────────────────────────────────────────────────
# Total overhead minutes from city terminal to your office (transit + walking)
COMMUTE_OVERHEAD_MIN=43
